rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate Land Seller listings
    function isValidSeller(data) {
      return data.keys().hasAll(['ownerName', 'phone', 'locality', 'landSize', 'expectedPrice', 'khataType', 'createdAt', 'status'])
        && data.ownerName is string && data.ownerName.size() <= 100
        && data.phone is string && data.phone.size() <= 15
        && data.locality is string && data.locality.size() <= 100
        && (data.email == null || (data.email is string && data.email.size() <= 100))
        && data.landSize is number
        && (data.facing == null || (data.facing is string && data.facing.size() <= 20))
        && data.expectedPrice is number
        && data.khataType is string && data.khataType.size() <= 50
        && (data.hasTitleDeed == null || data.hasTitleDeed is bool)
        && (data.surveyNumber == null || (data.surveyNumber is string && data.surveyNumber.size() <= 50))
        && (data.description == null || (data.description is string && data.description.size() <= 1000))
        && data.createdAt is string
        && data.status is string && data.status.size() <= 30;
    }

    // Helper to validate Land Buyer requests
    function isValidBuyer(data) {
      return data.keys().hasAll(['buyerName', 'phone', 'preferredLocalities', 'minSize', 'maxBudget', 'preferredKhata', 'purpose', 'createdAt', 'status'])
        && data.buyerName is string && data.buyerName.size() <= 100
        && data.phone is string && data.phone.size() <= 15
        && (data.email == null || (data.email is string && data.email.size() <= 100))
        && data.preferredLocalities is string && data.preferredLocalities.size() <= 200
        && data.minSize is number
        && data.maxBudget is number
        && data.preferredKhata is string && data.preferredKhata.size() <= 50
        && data.purpose is string && data.purpose.size() <= 50
        && (data.additionalInfo == null || (data.additionalInfo is string && data.additionalInfo.size() <= 1000))
        && data.createdAt is string
        && data.status is string && data.status.size() <= 30;
    }

    // Land Sellers collection permissions
    match /land_sellers/{sellerId} {
      allow create: if isValidSeller(request.resource.data);
      allow read: if true; // Public can see active listings, agents can fetch them
      allow update, delete: if false; // System-managed / immutable once posted
    }

    // Land Buyers collection permissions
    match /land_buyers/{buyerId} {
      allow create: if isValidBuyer(request.resource.data);
      allow read: if true; // Public can browse matching demands, agents can fetch them
      allow update, delete: if false; // System-managed / immutable once posted
    }
  }
}
